{
  "answer_agent": {
    "provider": "ollama",
    "model": "llama3.2"
  },
  "verifier_agent": {
    "provider": "ollama",
    "model": "llama3.2"
  },
  "retrieval": {
    "embedding_model": "NeuML/pubmedbert-base-embeddings",
    "knowledge_base_path": "data/knowledge_base.json",
    "faiss_dir": "artifacts/faiss_kb",
    "top_k": 5,
    "fetch_k": 15,
    "min_score_threshold": 0.3,
    "max_chunk_words": 200,
    "use_hybrid_search": true,
    "rebuild": false
  },
  "runtime": {
    "data_dir": "data",
    "eval_split": "dev",
    "knowledge_split": "train",
    "sample_size": 150,
    "knowledge_limit": 50000,
    "sleep_seconds": 0.0
  }
}
